# Local PostgreSQL / PostGIS dev container
POSTGRES_HOST=localhost
POSTGRES_PORT=5435
POSTGRES_DB=dashboard
POSTGRES_USER=postgres
POSTGRES_PASSWORD=SSYS
DATABASE_URL=postgresql://postgres:SSYS@localhost:5435/dashboard

# EMIS map tiles (maptiler.com → account → API keys → free plan works)
# Without this key the map falls back to a minimal demo style (no real tiles)
EMIS_MAPTILER_KEY=
# EMIS_MAP_MODE=online   # online | offline | auto (default: auto)

# WB Seller API token (Settings → API Access in WB cabinet)
# Required permissions: Prices & Discounts
WB_API_TOKEN=

# Base URL for opening strategy source documents from KPI provenance
# Example: https://sharepoint.example.com/sites/strategy-docs/
STRATEGY_DOCUMENT_BASE_URL=
